// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ── Keychain AR experiences ───────────────────────────────────────────────────
model ARExperience {
  id         String   @id @default(cuid())
  code       String   @unique
  message    String   @default("")
  imageUrl   String   @default("")
  type       String   @default("keychain")
  claimed    Boolean  @default(false)

  // ── TWO SEPARATE FIELDS — never conflate these ──────────────────────────
  // theme      = the PHYSICAL keychain design index (0-4).
  //              Set by admin at bulk-generate time. Maps to addAnchor(theme)
  //              in master-themes.mind. NEVER changed after creation.
  // colorIndex = the AR overlay color the USER chose at claim time (0-4).
  //              Defaults to match theme so unclaimed looks consistent,
  //              but is set independently by the user during setup.
  theme      Int      @default(0)
  colorIndex Int      @default(0)

  isActive   Boolean  @default(true)
  scanCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItem  OrderItem?

  @@index([code])
}

// ── Sticker AR experiences ────────────────────────────────────────────────────
model StickerExperience {
  id          String   @id @default(cuid())
  code        String   @unique
  targetImage String
  assetUrl    String   @default("")
  message     String   @default("")
  isActive    Boolean  @default(true)
  scanCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItem OrderItem?

  @@index([code])
}

// ── Products (shop inventory) ─────────────────────────────────────────────────
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  type        String
  price       Int
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  imageUrl    String   @default("")
  features    String[] @default([])
  theme       String   @default("love")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]

  @@index([slug])
  @@index([type])
}

// ── Orders ────────────────────────────────────────────────────────────────────
model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  status          String   @default("pending")
  paymentStatus   String   @default("pending")
  paymentMethod   String   @default("cod")
  paymentId       String?

  customerName    String
  customerEmail   String
  customerPhone   String

  addressLine1    String
  addressLine2    String   @default("")
  city            String
  state           String
  pincode         String
  country         String   @default("India")

  subtotal        Int
  shippingCharge  Int      @default(0)
  discount        Int      @default(0)
  total           Int

  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]

  @@index([orderNumber])
  @@index([customerEmail])
  @@index([status])
}

// ── Order Items ───────────────────────────────────────────────────────────────
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int      @default(1)
  unitPrice   Int
  total       Int

  arExperienceId      String?  @unique
  stickerExperienceId String?  @unique

  createdAt   DateTime @default(now())

  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product            @relation(fields: [productId], references: [id])
  arExperience      ARExperience?      @relation(fields: [arExperienceId], references: [id])
  stickerExperience StickerExperience? @relation(fields: [stickerExperienceId], references: [id])

  @@index([orderId])
  @@index([productId])
}
